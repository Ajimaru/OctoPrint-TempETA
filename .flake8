[flake8]
# Allow slightly longer lines to match project style (OctoPrint templates use 120 cols).
max-line-length = 120

# Ignore a couple compatibility rules that conflict with Black formatting where used.
extend-ignore = E203, W503

# Common excludes
exclude = .git,__pycache__,build,dist,.venv,.tox,*.egg-info

per-file-ignores =
    setup.py: E265,E266,E501,E402,E722
    # Tests use long, descriptive mock/assert lines; the pre-commit flake8
    # hook pins --max-line-length=88 (stricter than the 120 above), which
    # would otherwise flag pre-existing E501s on unrelated lines.
    tests/*.py: E501
