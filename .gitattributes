# Enforce LF line endings for shell scripts and git hooks
# This helps avoid CRLF-related issues on CI and Unix environments.
*.sh text eol=lf
.githooks/* text eol=lf
.development/*.sh text eol=lf
.codacy/*.sh text eol=lf
scripts/*.sh text eol=lf

# PowerShell scripts use CRLF (Windows convention)
*.ps1 text eol=crlf

# Ensure common text files also use LF
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf

# Frontend / template assets
*.js text eol=lf
*.less text eol=lf
*.css text eol=lf
*.jinja2 text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Translation files (gettext)
*.po text eol=lf
*.pot text eol=lf
*.mo binary

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.zip binary
*.gz binary
